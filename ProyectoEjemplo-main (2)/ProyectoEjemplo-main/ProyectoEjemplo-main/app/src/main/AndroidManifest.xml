<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.cbtis.plantillabase">
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PlantillaBase"
        android:usesCleartextTraffic="true">
        <activity android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".SegundaActivity"/>
        <activity android:name=".TerceraActivity"/>
        <activity android:name=".CuartaActivity"/>
        <activity android:name=".QuintaActivity" android:exported="false" />
        <activity android:name=".SextaActivity"/>
        <activity android:name=".SeptimaActivity" android:exported="false" />
    </application>

</manifest>